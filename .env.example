# ── App ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=

# ── Official data source endpoints (configure with official URLs only) ─
# Leave empty in development: the app falls back to small bundled sample
# data and clear "unavailable" states. In production, point these at
# official FIFA / federation / broadcaster endpoints or feeds that you
# are legally allowed to use.
# Example (user-approved community dataset, public domain, no key needed):
# OFFICIAL_FIFA_FIXTURES_URL=https://raw.githubusercontent.com/openfootball/worldcup.json/master/2026/worldcup.json
OFFICIAL_FIFA_FIXTURES_URL=
OFFICIAL_FIFA_STANDINGS_URL=
OFFICIAL_FIFA_MATCH_CENTRE_URL=
OFFICIAL_FIFA_TEAMS_URL=
OFFICIAL_FEDERATION_SQUADS_URL=
OFFICIAL_BROADCASTERS_URL=
OFFICIAL_TICKETS_URL=
OFFICIAL_NEWS_RSS_URL=
OFFICIAL_STADIUMS_URL=
OFFICIAL_TRAVEL_URL=
OFFICIAL_WATCH_PARTIES_URL=

# ── Optional third-party APIs (only if allowed by their terms) ─────────
WEATHER_API_KEY=
MAPS_API_KEY=

# ── Security ───────────────────────────────────────────────────────────
ADMIN_PASSWORD=
CRON_SECRET=
